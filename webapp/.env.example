# webapp/.env.example
# Copy this to .env and fill in values before running

DJANGO_ENV=development          # development | production
SECRET_KEY=your-secret-key-here
DEBUG=True

# PostgreSQL (production only — leave blank for development)
DB_NAME=Detectra_db
DB_USER=Detectra_user
DB_PASSWORD=your-db-password
DB_HOST=localhost
DB_PORT=5432

# Paths
CHECKPOINT_PATH=../checkpoints/best_acc.pt